    {
      "type": "text",
      "id": "t_evidence_json",
      "x": 1172,
      "y": 390,
      "width": 376,
      "height": 370,
      "text": "// Round N: messages sent to LLM\n[system, user, ...history]\ntoolSchemas: [{name:\"weatherTool\",...}]\n\n// LLM responds with tool_calls\n{\n  role: \"assistant\",\n  tool_calls: [{\n    id: \"call_abc\",\n    function: {\n      name: \"weatherTool\",\n      arguments: \"{\\\"city\\\":\\\"Beijing\\\"}\"\n    }\n  }]\n}\n\n// Spring AI executes → adds result\n{\n  role: \"tool\",\n  tool_call_id: \"call_abc\",\n  content: \"28C Sunny\"\n}\n\n// Round N+1: messages now include result\n// LLM reasons again → Act or final answer",
      "originalText": "// Round N: messages sent to LLM\n[system, user, ...history]\ntoolSchemas: [{name:\"weatherTool\",...}]\n\n// LLM responds with tool_calls\n{\n  role: \"assistant\",\n  tool_calls: [{\n    id: \"call_abc\",\n    function: {\n      name: \"weatherTool\",\n      arguments: \"{\\\"city\\\":\\\"Beijing\\\"}\"\n    }\n  }]\n}\n\n// Spring AI executes → adds result\n{\n  role: \"tool\",\n  tool_call_id: \"call_abc\",\n  content: \"28C Sunny\"\n}\n\n// Round N+1: messages now include result\n// LLM reasons again → Act or final answer",
      "fontSize": 11,
      "fontFamily": 4,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 100099,
      "version": 1,
