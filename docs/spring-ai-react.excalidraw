    {
      "type": "text",
      "id": "t_fix_code",
      "x": 1172,
      "y": 832,
      "width": 376,
      "height": 78,
      "text": "@Bean ToolExecutionExceptionProcessor processor() {\n  return DefaultToolExecutionExceptionProcessor\n    .builder()\n    .rethrowExceptions(List.of(\n        MaxStepsExceededException.class))\n    .build();\n}",
      "originalText": "@Bean ToolExecutionExceptionProcessor processor() {\n  return DefaultToolExecutionExceptionProcessor\n    .builder()\n    .rethrowExceptions(List.of(\n        MaxStepsExceededException.class))\n    .build();\n}",
      "fontSize": 10,
      "fontFamily": 4,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
